---
import { profile } from '../data/content.js';
---
<nav id="nav" class="fixed top-0 inset-x-0 z-50 backdrop-blur-md bg-bg/70 border-b border-transparent transition-colors duration-300">
  <div class="max-w-content mx-auto px-6 py-3.5 flex items-center justify-between">
    <a href="#top" class="font-mono font-extrabold tracking-tight text-[15px]">
      tishan<span class="text-accent">.</span>sh<span class="cursor-blink ml-px" style="height:13px"></span>
    </a>
    <div class="hidden md:flex gap-7 font-mono text-[13px] text-muted">
      <a href="#about" class="nav-link relative hover:text-ink transition-colors">about</a>
      <a href="#stack" class="nav-link relative hover:text-ink transition-colors">stack</a>
      <a href="#work" class="nav-link relative hover:text-ink transition-colors">work</a>
      <a href="#journey" class="nav-link relative hover:text-ink transition-colors">journey</a>
    </div>
    <div class="flex items-center gap-3">
      <button id="theme-toggle" type="button" aria-label="Toggle theme"
        class="w-9 h-9 grid place-items-center border border-line rounded-lg text-muted hover:text-accent hover:border-accent transition-colors">
        <svg class="icon-moon" width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>
        <svg class="icon-sun hidden" width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/><line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/></svg>
      </button>
      <a href="#contact" class="hidden sm:inline-block btn-shine font-mono text-[13px] border border-line px-3.5 py-1.5 rounded-lg text-ink hover:border-accent hover:text-accent transition-colors">
        get in touch →
      </a>
      <button id="menu-toggle" type="button" aria-label="Open menu" aria-expanded="false" aria-controls="mobile-menu"
        class="md:hidden w-9 h-9 grid place-items-center border border-line rounded-lg text-muted hover:text-accent hover:border-accent transition-colors">
        <svg class="icon-burger" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
        <svg class="icon-close hidden" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
      </button>
    </div>
  </div>

  <!-- mobile drawer -->
  <div id="mobile-menu" class="md:hidden grid grid-rows-[0fr] transition-[grid-template-rows] duration-300 ease-out border-t border-transparent">
    <div class="overflow-hidden">
      <div class="max-w-content mx-auto px-6 py-4 flex flex-col gap-1 font-mono text-[15px]">
        <a href="#about"   class="m-link py-2.5 text-muted hover:text-accent transition-colors">about</a>
        <a href="#stack"   class="m-link py-2.5 text-muted hover:text-accent transition-colors">stack</a>
        <a href="#work"    class="m-link py-2.5 text-muted hover:text-accent transition-colors">work</a>
        <a href="#journey" class="m-link py-2.5 text-muted hover:text-accent transition-colors">journey</a>
        <a href="#contact" class="m-link py-2.5 text-accent">get in touch →</a>
      </div>
    </div>
  </div>
</nav>

<style>
  .nav-link::before {
    content: '';
    position: absolute;
    left: 0; bottom: -4px;
    width: 0; height: 1px;
    background: #22d3ee;
    transition: width .25s;
  }
  .nav-link:hover::before { width: 100%; }
</style>

<script>
  const nav = document.getElementById('nav');
  const onScroll = () => nav?.classList.toggle('border-line', window.scrollY > 20);
  window.addEventListener('scroll', onScroll, { passive: true });
  onScroll();

  // Theme toggle
  const root = document.documentElement;
  const btn = document.getElementById('theme-toggle');
  const moon = btn?.querySelector('.icon-moon');
  const sun = btn?.querySelector('.icon-sun');
  function syncIcons() {
    const light = root.classList.contains('light');
    moon?.classList.toggle('hidden', light);
    sun?.classList.toggle('hidden', !light);
  }
  syncIcons();
  btn?.addEventListener('click', () => {
    const light = root.classList.toggle('light');
    try { localStorage.setItem('theme', light ? 'light' : 'dark'); } catch (e) {}
    syncIcons();
  });

  // Mobile menu
  const menuBtn = document.getElementById('menu-toggle');
  const menu = document.getElementById('mobile-menu');
  const burger = menuBtn?.querySelector('.icon-burger');
  const close = menuBtn?.querySelector('.icon-close');
  let open = false;
  function setMenu(next: boolean) {
    open = next;
    menu?.style.setProperty('grid-template-rows', open ? '1fr' : '0fr');
    menu?.classList.toggle('border-line', open);
    menuBtn?.setAttribute('aria-expanded', String(open));
    menuBtn?.setAttribute('aria-label', open ? 'Close menu' : 'Open menu');
    burger?.classList.toggle('hidden', open);
    close?.classList.toggle('hidden', !open);
  }
  menuBtn?.addEventListener('click', () => setMenu(!open));
  menu?.querySelectorAll('.m-link').forEach((a) => a.addEventListener('click', () => setMenu(false)));
</script>
