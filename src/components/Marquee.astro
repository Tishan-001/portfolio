---
import { stack } from '../data/content.js';
const items = stack.flatMap((s) => s.items.map((it) => it.replace(/\s*·.*$/, '')));
const unique = [...new Set(items)];
---
<div class="marquee relative z-10 py-6 border-y border-line/60 bg-bg-2/40" aria-hidden="true">
  <div class="pointer-events-none absolute inset-y-0 left-0 w-24 bg-gradient-to-r from-bg to-transparent z-10"></div>
  <div class="pointer-events-none absolute inset-y-0 right-0 w-24 bg-gradient-to-l from-bg to-transparent z-10"></div>
  <div class="marquee-track">
    {[0, 1].map(() => (
      <div class="flex items-center shrink-0">
        {unique.map((it) => (
          <span class="flex items-center font-mono text-[13px] tracking-[.14em] uppercase text-dim whitespace-nowrap">
            <span class="px-6 hover:text-accent transition-colors">{it}</span>
            <span class="text-accent-2/60">✦</span>
          </span>
        ))}
      </div>
    ))}
  </div>
</div>
