---
import { profile } from '../data/content.js';
---
<header id="top" class="relative z-10 pt-[150px] pb-24 overflow-hidden">
  <div class="orb float-slow -z-10 -top-10 -left-16 w-72 h-72 bg-accent/[.12]"></div>
  <div class="orb float-slower -z-10 top-40 right-0 w-80 h-80 bg-accent-2/[.10]"></div>
  <div class="max-w-content mx-auto px-6">
    <div class="grid lg:grid-cols-[1fr_auto] gap-12 items-start">
      <div>
        <div class="reveal font-mono text-[13px] text-accent tracking-wide flex items-center gap-2.5 mb-5">
          <span class="pulse-dot"></span> SOFTWARE ENGINEER @ CODIMITE · {profile.location.toUpperCase()}
        </div>

        <h1 class="reveal font-mono font-extrabold leading-[1.02] tracking-[-2px] text-[clamp(38px,7vw,72px)]">
          {profile.name}<br />
          <span class="gradient-flow">builds &amp; ships</span> systems.
        </h1>

        <p class="reveal mt-5 max-w-[560px] text-[18px] text-muted">{profile.blurb}</p>

        <div class="reveal mt-6 flex flex-wrap gap-2.5 font-mono text-[12.5px]">
          {profile.stats.map((s) => {
            const n = /^\d+$/.test(s.value) ? s.value : null;
            return (
              <span class="border border-line bg-bg-2 px-3 py-1.5 rounded-full text-muted transition-colors hover:border-accent/50 hover:text-ink">
                {n
                  ? <b class="text-ink font-medium tabular-nums" data-count={n}>0</b>
                  : <b class="text-ink font-medium">{s.value}</b>} {s.label}
              </span>
            );
          })}
        </div>

        <div class="reveal mt-7 flex flex-wrap gap-3.5">
          <a href="#work" class="magnetic btn-shine font-mono text-[14px] px-5 py-3 rounded-[10px] bg-accent text-[#04121a] font-bold shadow-[0_10px_30px_-10px_rgba(34,211,238,.7)] hover:shadow-[0_16px_40px_-10px_rgba(34,211,238,.85)] transition-shadow inline-flex items-center gap-2">View work ↓</a>
          <a href={profile.cv} download class="magnetic font-mono text-[14px] px-5 py-3 rounded-[10px] border border-accent/40 text-accent hover:border-accent hover:bg-accent/[.06] transition-colors inline-flex items-center gap-2">
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
            Download CV
          </a>
          <a href={profile.socials.github} target="_blank" rel="noopener" class="font-mono text-[14px] px-5 py-3 rounded-[10px] border border-line text-ink hover:border-accent hover:text-accent transition-colors">GitHub →</a>
        </div>
      </div>

      <!-- headshot -->
      <div class="reveal hidden lg:block relative shrink-0 mt-2">
        <div class="avatar-aura absolute -inset-6 rounded-full"></div>
        <div class="absolute -inset-3 rounded-full bg-gradient-to-br from-accent/20 to-accent-2/10 blur-xl"></div>
        <div class="relative w-[250px] h-[250px] rounded-full overflow-hidden border border-line bg-panel">
          <img src={profile.avatar} alt={`${profile.name} — portrait`} width="250" height="250" loading="eager"
            class="w-full h-full object-cover"
            onerror="this.style.display='none';this.nextElementSibling.style.display='flex';" />
          <div class="avatar-fallback w-full h-full hidden items-center justify-center font-mono text-[64px] text-dim bg-gradient-to-b from-panel to-bg-2">TS</div>
        </div>
        <span class="absolute -bottom-3 -right-3 font-mono text-[11px] bg-bg border border-line text-accent-2 px-3 py-1.5 rounded-full">● online</span>
      </div>
    </div>

    <!-- terminal -->
    <div class="reveal mt-14 border border-line rounded-[14px] overflow-hidden bg-gradient-to-b from-panel to-bg-2 shadow-[0_30px_80px_-40px_rgba(0,0,0,.9)]">
      <div class="flex items-center gap-2 px-4 py-3 border-b border-line bg-white/[.02]">
        <i class="w-3 h-3 rounded-full bg-[#ff5f57]"></i>
        <i class="w-3 h-3 rounded-full bg-[#febc2e]"></i>
        <i class="w-3 h-3 rounded-full bg-[#28c840]"></i>
        <span class="ml-2.5 font-mono text-[12px] text-dim">~/tishan — developer.ts</span>
      </div>
      <div id="term" class="px-[22px] pt-[22px] pb-[26px] font-mono text-[13.5px] leading-[1.85] min-h-[230px]"></div>
    </div>
  </div>
</header>

<script>
  const lines = [
    '<span class="text-dim">// initializing developer profile...</span>',
    '<span class="text-accent">class</span> <span class="text-warn">Developer</span> {',
    '&nbsp;&nbsp;role&nbsp;&nbsp;= <span class="text-accent-2">"Software Engineer @ Codimite"</span>;',
    '&nbsp;&nbsp;stack = [<span class="text-accent-2">"Python"</span>, <span class="text-accent-2">"Go"</span>, <span class="text-accent-2">".NET"</span>, <span class="text-accent-2">"TypeScript"</span>, <span class="text-accent-2">"GCP"</span>];',
    '&nbsp;&nbsp;<span class="text-warn">build</span>() {',
    '&nbsp;&nbsp;&nbsp;&nbsp;<span class="text-accent">return</span> <span class="text-accent-2">"Scalable, secure &amp; production-ready systems 🚀"</span>;',
    '&nbsp;&nbsp;}',
    '}',
    '',
    '<span class="text-accent">const</span> me = <span class="text-accent">new</span> <span class="text-warn">Developer</span>();',
    'me.<span class="text-warn">build</span>(); <span class="text-dim">// → ready to ship ✓</span>',
  ];

  const term = document.getElementById('term');
  const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  const strip = (s: string) => s.replace(/<[^>]+>/g, '');
  const committed: string[] = [];

  function render(partial: string) {
    let html = committed.map((l) => `<div>${l || '&nbsp;'}</div>`).join('');
    html += `<div>${partial.replace(/ /g, '&nbsp;') || '&nbsp;'}<span class="cursor-blink"></span></div>`;
    if (term) term.innerHTML = html;
  }

  if (reduce) {
    if (term) term.innerHTML = lines.map((l) => `<div>${l || '&nbsp;'}</div>`).join('');
  } else {
    let li = 0, ci = 0;
    function type() {
      if (li >= lines.length) return;
      const plain = strip(lines[li]);
      if (ci <= plain.length) {
        render(plain.slice(0, ci));
        ci++;
        setTimeout(type, plain.length ? 20 : 110);
      } else {
        committed.push(lines[li]);
        li++; ci = 0;
        setTimeout(type, 140);
      }
    }
    setTimeout(type, 700);
  }
</script>
